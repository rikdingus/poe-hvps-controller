# Project Korstmos -- Dashboard backend environment template.
# Copy this file to `.env` and adjust the values for your station.
#
#   PowerShell:   Copy-Item .env.example .env
#   bash:         cp .env.example .env

# --- MikroTik (router / PoE switch) -----------------------------------------
# IP of the RB5009. The dashboard polls this via SNMP for PoE telemetry and
# uses it to cut power on a port when the safety guardian fires.
MIKROTIK_IP=192.168.88.1

# Community string for SNMP READ (telemetry only). Default MikroTik is "public".
SNMP_COMMUNITY=public

# Community string for SNMP WRITE (used to flip PoE ports off in an emergency).
# MikroTik default is "private" -- you SHOULD change this in production.
SNMP_COMMUNITY_WRITE=private

# PoE control method: "routeros-snmp" (default) or "swos-http"
POE_CONTROL_METHOD=routeros-snmp

# Switch credentials (required if POE_CONTROL_METHOD=swos-http)
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=

# --- MQTT (optional Home Assistant bridge) ----------------------------------
# Set to mqtt://<broker>:1883. Leave the default if you don't run HA.
MQTT_BROKER=mqtt://localhost:1883

# --- Config file overrides --------------------------------------------------
# Paths are resolved relative to dashboard/app/ at runtime.
NODES_CONFIG=../config/nodes.json
SAFETY_CONFIG=../config/safety_limits.json

# --- Dashboard API auth -----------------------------------------------------
# Bearer token required for WRITE endpoints (reboot-detector, emergency-stop).
# MUST be at least 16 characters or the server will refuse writes entirely.
# Generate with: openssl rand -hex 32   (or any password generator)
# Read-only telemetry endpoints stay open so the frontend can poll freely.
DASHBOARD_API_TOKEN=

# --- Demo / development mode -------------------------------------------
# When 'true', the backend synthesizes realistic telemetry for all nodes
# in dashboard/config/nodes.demo.json instead of doing any real fetch/SNMP/
# MQTT I/O -- useful for frontend visual testing without hardware attached.
# Does NOT change safety_guardian.js's cut logic. See
# demo-mode-draft/notes.md in the PR for details.
DEMO_MODE=false
